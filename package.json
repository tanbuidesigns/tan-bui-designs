{
  "name": "tan-bui-designs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:homepage-logos": "node scripts/generate-homepage-logo-manifest.mjs",
    "generate:playground": "node scripts/generate-playground-manifest.mjs",
    "generate:manifests": "node scripts/generate-content-manifests.mjs",
    "predev": "npm run generate:manifests",
    "build": "next build --webpack",
    "prebuild": "npm run generate:manifests",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "prepreview": "npm run generate:manifests",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy": "npm run generate:manifests",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preupload": "npm run generate:manifests",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@keystatic/core": "^0.5.51",
    "@keystatic/next": "^5.0.4",
    "@markdoc/markdoc": "^0.5.7",
    "@opennextjs/cloudflare": "^1.20.1",
    "better-auth": "1.6.23",
    "jose": "6.2.3",
    "next": "^16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  }
}
